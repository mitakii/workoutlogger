# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

DB_CONNECTION_STRING=Host=your-db-host;Port=5432;Database=workout-dev;Username=your-user;Password=your-password;Pooling=true;SSL Mode=Require

JWT_ISSUER=https://your-domain
JWT_AUDIENCE=https://your-domain
JWT_SIGNING_KEY=generate-a-long-random-value

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
